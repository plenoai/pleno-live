{
  "name": "pleno-live",
  "version": "1.14.1",
  "private": true,
  "main": "expo-router/entry",
  "expo": {
    "autolinking": {
      "exclude": [
        "react-native-svg"
      ]
    }
  },
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch apps/server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --web --port ${EXPO_PORT:-8081}",
    "build": "esbuild apps/server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "qr": "node scripts/generate_qr.mjs",
    "storybook": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --web",
    "storybook:ios": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED=true expo run:ios",
    "even:g2:dev": "vite --config apps/even-g2/vite.config.ts",
    "even:g2:check": "tsc --project apps/even-g2/tsconfig.json --noEmit",
    "even:g2:build": "pnpm even:g2:check && vite build --config apps/even-g2/vite.config.ts",
    "even:g2:pack": "pnpm even:g2:build && mkdir -p dist && rm -f dist/pleno-live-g2.ehpk && evenhub pack apps/even-g2/app.json apps/even-g2/dist -o dist/pleno-live-g2.ehpk && test -s dist/pleno-live-g2.ehpk",
    "even:g2:simulate": "evenhub-simulator http://localhost:5174"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@evenrealities/even_hub_sdk": "0.0.12",
    "@mykin-ai/expo-audio-stream": "^0.3.5",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@ronradtke/react-native-markdown-display": "^9.0.3",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "11.18.0",
    "@trpc/react-query": "11.18.0",
    "@trpc/server": "11.18.0",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^2.0.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "expo": "~56.0.16",
    "expo-asset": "~56.0.20",
    "expo-audio": "~56.0.12",
    "expo-build-properties": "~56.0.23",
    "expo-constants": "~56.0.21",
    "expo-crypto": "~56.0.4",
    "expo-device": "^56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-keep-awake": "~56.0.3",
    "expo-linking": "~56.0.15",
    "expo-router": "~56.2.15",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~56.0.13",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.22",
    "expo-updates": "~56.0.22",
    "expo-video": "~56.1.4",
    "express": "^4.22.1",
    "framer-motion": "^12.42.2",
    "jose": "6.2.3",
    "lucide-react": "^1.25.0",
    "mysql2": "^3.23.1",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-audio-api": "^0.13.2",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "serverless-http": "^4.0.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-ondevice-actions": "10",
    "@storybook/addon-ondevice-controls": "10",
    "@storybook/react-native": "10",
    "@evenrealities/evenhub-cli": "0.1.13",
    "@evenrealities/evenhub-simulator": "0.8.0",
    "@types/express": "^4.17.25",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.17",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~56.0.4",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.9.5",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "qs": ">=6.15.2",
      "uuid": ">=11.1.1",
      "vite": ">=6.0.0"
    },
    "patchedDependencies": {
      "@mykin-ai/expo-audio-stream": "patches/@mykin-ai__expo-audio-stream.patch"
    }
  }
}
