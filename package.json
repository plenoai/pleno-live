{
  "name": "pleno-live",
  "version": "1.13.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch apps/server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --web --port ${EXPO_PORT:-8081}",
    "build": "esbuild apps/server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "qr": "node scripts/generate_qr.mjs",
    "storybook": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --web",
    "storybook:ios": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED=true expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@mykin-ai/expo-audio-stream": "^0.3.5",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.8.12",
    "@react-navigation/elements": "^2.9.2",
    "@react-navigation/native": "^7.1.25",
    "@ronradtke/react-native-markdown-display": "^8.1.0",
    "@tanstack/react-query": "^5.100.14",
    "@trpc/client": "11.8.1",
    "@trpc/react-query": "11.8.1",
    "@trpc/server": "11.8.1",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "expo": "~56.0.5",
    "expo-asset": "^12.0.12",
    "expo-audio": "~56.0.11",
    "expo-build-properties": "^56.0.16",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~15.0.8",
    "expo-device": "^56.0.4",
    "expo-document-picker": "^14.0.8",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~56.0.13",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "^56.0.15",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "^14.0.9",
    "expo-updates": "~29.0.16",
    "expo-video": "~56.1.2",
    "express": "^4.22.1",
    "framer-motion": "^12.40.0",
    "jose": "6.2.3",
    "lucide-react": "^0.562.0",
    "mysql2": "^3.16.0",
    "nativewind": "^4.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-audio-api": "^0.12.0",
    "react-native-gesture-handler": "~3.0.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "serverless-http": "^4.0.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-ondevice-actions": "8",
    "@storybook/addon-ondevice-controls": "8",
    "@storybook/react-native": "8",
    "@types/express": "^4.17.25",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.1.17",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.7.4",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
